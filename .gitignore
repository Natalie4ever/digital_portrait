# =========================================
# digital-portrait/.gitignore (可选模板版)
# 用法：
# 1) 默认未注释 = 会忽略（不上传）
# 2) 以 "# " 开头 = 可选规则，删除开头的 "# " 即启用
# =========================================

# --- 必选：Python 缓存与构建产物 ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/

# --- 必选：虚拟环境 ---
venv/
venv*/
.venv/
env/
ENV/

# --- 必选：前端依赖与日志 ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 必选：通用构建产物 ---
dist/
build/
dist-ssr/

# --- 必选：临时文件 ---
*.tmp
*.temp

# --- 必选：编辑器与系统文件 ---
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln

# --- 推荐：本地 IDE 设置（如需共享工作区配置可注释掉） ---
.vscode/*
!.vscode/extensions.json

# --- 推荐：敏感环境变量 ---
.env
.env.local
.env.*.local

# --- 可选：数据库文件（本地开发常用，建议忽略） ---
*.db
*.sqlite
*.sqlite3

# --- 可选：Excel 导入导出文件 ---
# *.xlsx
# *.xls

# --- 可选：压缩包 / 备份文件 ---
# *.zip
# *.rar
# *.7z
# *.bak

# --- 可选：前端本地配置 ---
*.local

# --- 项目自定义 ---
.claude/
.claude/settings.local.json
TZfrontend
TZfrontend.backup
